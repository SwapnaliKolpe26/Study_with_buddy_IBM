# ============================================================
#  Study With Buddy — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit your real .env file to version control.
# ============================================================

# ----------------------------------------------------------
# IBM Cloud / watsonx.ai Credentials
# ----------------------------------------------------------
# Your IBM Cloud API Key — get it from:
#   https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID — get it from your watsonx.ai project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai API endpoint (region-specific)
# Default: Dallas (us-south)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ----------------------------------------------------------
# Flask Application Settings
# ----------------------------------------------------------
# A long random string used to sign session cookies
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Set to "development" for debug mode, "production" for live
FLASK_ENV=development

# Port the Flask app will run on (default: 5000)
FLASK_PORT=5000
